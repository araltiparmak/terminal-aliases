# Define base directories
export DEV_FOLDER="dev"
export REPO_NAME="terminal-aliases"
export REPO_PATH="$DEV_FOLDER/$REPO_NAME"

# general
alias a="open -e ~/$DEV_FOLDER/$REPO_NAME/aliases"
alias z="open -e ~/.zshrc"
alias d="cd ~/desktop"
alias dd="cd ~/$DEV_FOLDER"
alias c="clear"
alias o="open ."
alias ..="cd .."
alias md="mkdir"
alias ua="cd ~/$REPO_NAME && git pull && source ~/$REPO_NAME/aliases"

# claude
alias cc="claude"

# git
alias add="git add ."
alias gi="git init"
alias gs="git status"
alias gf="git fetch"
alias gp="git pull"
alias gl="git clone"
alias gc="git commit"
alias gca="git commit --amend --no-edit"

# yarn
alias yi="yarn install"
alias yb="yarn build"
alias ys="yarn start"
alias yw="yarn web"
alias yt="yarn test"
alias yl="yarn lint"
alias yf="yarn format"

# npm
alias ni="npm init -y"
alias ns="npm run start"

# bun
alias bi="bun install"
alias bs="bun start"
alias bl="bun lint"
alias bf="bun format"

# terraform
alias ti="terraform init"
alias tp="terraform plan"
alias ta="terraform apply"
alias ta-ap="terraform apply -auto-approve"
alias tf="terraform fmt -recursive"
alias tv="terraform validate"

# terragrunt
alias tg="terragrunt"
alias tgp="terragrunt plan"
alias tga="terragrunt apply"
alias tgv="terragrunt validate"
alias tgf="terragrunt hcl fmt"

# docker
alias di="docker images"
alias dr="docker run"
alias dp="docker ps"
alias dk="docker kill"
alias dka="docker ps -q | xargs -r docker kill"
alias dcb="docker compose build"
alias dcu="docker compose up"

# java
alias jv="java -version"

# gradle
alias gb="gradle build"
alias gbr="gradle bootRun"


mc() {
   mkdir -p $1
   cd $1
}

update_aliases() {
    echo "Updating aliases from repository..."
    (cd "$REPO_PATH" && git pull) &&
    source "$REPO_PATH/aliases" &&
    echo "✅ Aliases updated successfully!"
}
alias ua="update_aliases"